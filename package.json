{
  "name": "procertify-studio",
  "private": true,
  "version": "1.3.5",
  "description": "Profesyonel Sertifika Tasarım ve Toplu Üretim Aracı",
  "main": "main.js",
  "homepage": "./",
  "author": {
    "name": "ProCertify Team",
    "email": "info@procertify.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/szgnemin1/ProCertify.git"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "start": "vite --host 0.0.0.0 --port 3000",
    "vps:dev": "vite --host 0.0.0.0 --port 5555",
    "vps:build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/server.cjs",
    "vps:start": "node dist/server.cjs",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.procertify.studio",
    "productName": "ProCertify Studio",
    "copyright": "Copyright © 2024 ProCertify",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "server.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ProCertify Studio"
    }
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jspdf": "^2.5.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "wait-on": "^9.0.4"
  }
}
